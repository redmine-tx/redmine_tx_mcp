<div class="box tabular">
  <p>
    <%= check_box_tag 'settings[enabled]', '1', @settings['enabled'], id: 'settings_enabled' %>
    <%= label_tag 'settings_enabled', 'Enable MCP Server' %>
  </p>

  <p>
    <%= label_tag 'settings_api_key', 'MCP API Key' %>
    <%= text_field_tag 'settings[api_key]', @settings['api_key'], placeholder: 'Enter API key for MCP authentication' %>
    <em>Used to authenticate MCP client connections</em>
  </p>

  <p>
    <%= label_tag 'settings_llm_provider', 'LLM Provider' %>
    <%= select_tag 'settings[llm_provider]',
          options_for_select([
            ['Anthropic Claude', 'anthropic'],
            ['OpenAI-Compatible (Ollama, vLLM, etc.)', 'openai'],
          ], @settings['llm_provider'] || 'anthropic'),
          id: 'settings_llm_provider' %>
  </p>

  <!-- Anthropic settings -->
  <div id="anthropic-settings">
    <p>
      <%= label_tag 'settings_claude_api_key', 'Claude API Key' %>
      <%= text_field_tag 'settings[claude_api_key]', @settings['claude_api_key'], placeholder: 'Enter Anthropic Claude API key' %>
      <em>Used for the AI chatbot feature. Get your key from <a href="https://console.anthropic.com/" target="_blank">Anthropic Console</a></em>
    </p>

    <p>
      <%= label_tag 'settings_claude_model', 'Claude Model' %>
      <span id="claude-model-wrapper" style="display: inline-flex; align-items: center; gap: 6px;">
        <%= select_tag 'settings[claude_model]',
              options_for_select([
                ['Claude 4.6 Opus', 'claude-opus-4-6'],
                ['Claude 4.6 Sonnet', 'claude-sonnet-4-6'],
                ['Claude 4.5 Haiku', 'claude-haiku-4-5-20251001'],
                ['Claude 4.5 Sonnet', 'claude-sonnet-4-5-20250514'],
                ['Claude 4.5 Opus', 'claude-opus-4-5-20250514'],
                ['Claude 3.5 Haiku', 'claude-3-5-haiku-latest'],
                ['Claude 3.5 Sonnet', 'claude-3-5-sonnet-latest'],
              ], @settings['claude_model'] || 'claude-sonnet-4-6'),
              id: 'settings_claude_model' %>
        <button type="button" id="claude-model-refresh" title="Refresh model list from Anthropic API"
                style="cursor: pointer; padding: 2px 6px; font-size: 14px; line-height: 1; border: 1px solid #ccc; border-radius: 3px; background: #f5f5f5;">&#x21bb;</button>
        <span id="claude-model-loading" style="display: none; font-size: 12px; color: #888;">Loading models...</span>
      </span>
      <em>Select the Claude model to use for the chatbot.</em>
    </p>
  </div>

  <!-- OpenAI-Compatible settings -->
  <div id="openai-settings" style="display: none;">
    <p>
      <%= label_tag 'settings_openai_endpoint_url', 'Endpoint URL' %>
      <%= text_field_tag 'settings[openai_endpoint_url]', @settings['openai_endpoint_url'],
            placeholder: 'http://localhost:11434/v1/chat/completions',
            style: 'width: 400px;' %>
      <em>OpenAI-compatible chat completions endpoint (e.g. Ollama: <code>http://localhost:11434/v1/chat/completions</code>)</em>
    </p>

    <p>
      <%= label_tag 'settings_openai_api_key', 'API Key (optional)' %>
      <%= text_field_tag 'settings[openai_api_key]', @settings['openai_api_key'],
            placeholder: 'Leave blank for local LLMs' %>
      <em>Optional. Only needed if your endpoint requires authentication.</em>
    </p>

    <p>
      <%= label_tag 'settings_openai_model', 'Model' %>
      <span id="openai-model-wrapper" style="display: inline-flex; align-items: center; gap: 6px;">
        <%= text_field_tag 'settings[openai_model]', @settings['openai_model'],
              id: 'settings_openai_model',
              list: 'openai-model-datalist',
              placeholder: 'e.g. qwen3.5',
              autocomplete: 'off',
              style: 'width: 250px;' %>
        <datalist id="openai-model-datalist"></datalist>
        <button type="button" id="openai-model-refresh" title="Refresh model list from endpoint"
                style="cursor: pointer; padding: 2px 6px; font-size: 14px; line-height: 1; border: 1px solid #ccc; border-radius: 3px; background: #f5f5f5;">&#x21bb;</button>
        <span id="openai-model-loading" style="display: none; font-size: 12px; color: #888;">Loading models...</span>
      </span>
      <em>Type a model name directly, or click refresh to load available models from the endpoint.</em>
    </p>
  </div>

  <script type="text/javascript">
  (function() {
    var providerSelect = document.getElementById('settings_llm_provider');
    var anthropicSection = document.getElementById('anthropic-settings');
    var openaiSection = document.getElementById('openai-settings');

    function toggleProviderSections() {
      var provider = providerSelect.value;
      anthropicSection.style.display = (provider === 'anthropic') ? '' : 'none';
      openaiSection.style.display = (provider === 'openai') ? '' : 'none';
    }

    providerSelect.addEventListener('change', toggleProviderSections);
    toggleProviderSections();

    // ─── Anthropic model loader ───
    var claudeSelect = document.getElementById('settings_claude_model');
    var claudeRefreshBtn = document.getElementById('claude-model-refresh');
    var claudeLoading = document.getElementById('claude-model-loading');

    function loadModels(selectEl, loadingEl, refreshBtnEl, providerParam, refresh) {
      var url = '<%= escape_javascript(url_for(controller: 'mcp_admin', action: 'models', only_path: true)) %>';
      url += '?provider=' + providerParam;
      if (refresh) url += '&refresh=1';

      loadingEl.style.display = 'inline';
      refreshBtnEl.disabled = true;

      var xhr = new XMLHttpRequest();
      xhr.open('GET', url, true);
      xhr.setRequestHeader('Accept', 'application/json');
      xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
      xhr.onreadystatechange = function() {
        if (xhr.readyState !== 4) return;

        loadingEl.style.display = 'none';
        refreshBtnEl.disabled = false;

        if (xhr.status !== 200) return;

        try {
          var data = JSON.parse(xhr.responseText);
          if (!data.success || !data.models || data.models.length === 0) return;

          var currentValue = selectEl.value;
          selectEl.innerHTML = '';

          var found = false;
          for (var i = 0; i < data.models.length; i++) {
            var m = data.models[i];
            var opt = document.createElement('option');
            opt.value = m.id;
            opt.textContent = m.display_name;
            if (m.id === currentValue) found = true;
            selectEl.appendChild(opt);
          }

          if (!found && currentValue) {
            var prev = document.createElement('option');
            prev.value = currentValue;
            prev.textContent = currentValue + ' (previously selected)';
            selectEl.insertBefore(prev, selectEl.firstChild);
          }

          selectEl.value = currentValue;
        } catch(e) {
          // parse error — keep fallback options
        }
      };
      xhr.send();
    }

    claudeRefreshBtn.addEventListener('click', function() {
      loadModels(claudeSelect, claudeLoading, claudeRefreshBtn, 'anthropic', true);
    });
    loadModels(claudeSelect, claudeLoading, claudeRefreshBtn, 'anthropic', false);

    // ─── OpenAI model loader ───
    var openaiModelInput = document.getElementById('settings_openai_model');
    var openaiDatalist = document.getElementById('openai-model-datalist');
    var openaiRefreshBtn = document.getElementById('openai-model-refresh');
    var openaiLoading = document.getElementById('openai-model-loading');

    function loadOpenaiModels(refresh) {
      var endpointUrl = document.getElementById('settings_openai_endpoint_url').value;
      var apiKey = document.getElementById('settings_openai_api_key').value;

      if (!endpointUrl) {
        openaiLoading.style.display = 'none';
        return;
      }

      var url = '<%= escape_javascript(url_for(controller: "mcp_admin", action: "models", only_path: true)) %>';
      url += '?provider=openai&endpoint_url=' + encodeURIComponent(endpointUrl);
      if (apiKey) url += '&api_key=' + encodeURIComponent(apiKey);
      if (refresh) url += '&refresh=1';

      openaiLoading.style.display = 'inline';
      openaiRefreshBtn.disabled = true;

      var xhr = new XMLHttpRequest();
      xhr.open('GET', url, true);
      xhr.setRequestHeader('Accept', 'application/json');
      xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
      xhr.onreadystatechange = function() {
        if (xhr.readyState !== 4) return;

        openaiLoading.style.display = 'none';
        openaiRefreshBtn.disabled = false;

        if (xhr.status !== 200) return;

        try {
          var data = JSON.parse(xhr.responseText);
          if (!data.models || data.models.length === 0) return;

          openaiDatalist.innerHTML = '';
          for (var i = 0; i < data.models.length; i++) {
            var opt = document.createElement('option');
            opt.value = data.models[i].id;
            openaiDatalist.appendChild(opt);
          }

          // If input is empty, auto-fill with first model
          if (!openaiModelInput.value && data.models.length > 0) {
            openaiModelInput.value = data.models[0].id;
          }
        } catch(e) {}
      };
      xhr.send();
    }

    openaiRefreshBtn.addEventListener('click', function() { loadOpenaiModels(true); });
    // Auto-load if provider is openai and endpoint is set
    if (providerSelect.value === 'openai') {
      loadOpenaiModels(false);
    }
  })();
  </script>

  <p>
    <%= label_tag 'settings_system_prompt', 'System Prompt' %>
    <%= text_area_tag 'settings[system_prompt]', @settings['system_prompt'],
                     rows: 8,
                     style: 'width: 100%; font-family: monospace;',
                     placeholder: 'Additional instructions for the AI assistant (optional)...' %>
    <em>Additional instructions appended to the built-in system prompt. The built-in prompt (tool docs, workflow, reporting guidelines) is always active. Leave blank if no extra instructions are needed.</em>
  </p>

  <p>
    <%= label_tag 'settings_allowed_origins', 'Allowed Origins' %>
    <%= text_area_tag 'settings[allowed_origins]', @settings['allowed_origins'], rows: 3, placeholder: 'localhost:3000\nexample.com\n\n(Leave blank to allow ALL origins)' %>
    <em>One origin per line. <strong>Leave completely blank to allow ALL origins (*)</strong></em>
  </p>

  <p>
    <%= label_tag 'settings_log_level', 'Log Level' %>
    <%= select_tag 'settings[log_level]',
          options_for_select([
            ['Debug', 'debug'],
            ['Info', 'info'],
            ['Warn', 'warn'],
            ['Error', 'error']
          ], @settings['log_level'] || 'info') %>
  </p>

  <p>
    <%= label_tag 'settings_max_request_size', 'Max Request Size (KB)' %>
    <%= number_field_tag 'settings[max_request_size]', @settings['max_request_size'] || 1024, min: 1 %>
    <em>Maximum size for MCP requests in KB</em>
  </p>

  <p>
    <%= check_box_tag 'settings[enable_caching]', '1', @settings['enable_caching'], id: 'settings_enable_caching' %>
    <%= label_tag 'settings_enable_caching', 'Enable Response Caching' %>
    <em>Cache frequently requested data to improve performance</em>
  </p>

  <p>
    <%= label_tag 'settings_cache_ttl', 'Cache TTL (seconds)' %>
    <%= number_field_tag 'settings[cache_ttl]', @settings['cache_ttl'] || 300, min: 1 %>
    <em>Time-to-live for cached responses</em>
  </p>

  <p>
    <%= label_tag 'settings_max_run_seconds', 'Max Run Seconds' %>
    <%= number_field_tag 'settings[max_run_seconds]', @settings['max_run_seconds'] || 180, min: 30, max: 900 %>
    <em>Maximum runtime per chatbot turn (default: 180). Increase this together with tool depth for long analysis or batch jobs.</em>
  </p>

  <p>
    <%= label_tag 'settings_max_tool_call_depth', 'Max Tool Call Depth' %>
    <%= number_field_tag 'settings[max_tool_call_depth]', @settings['max_tool_call_depth'] || 15, min: 1, max: 100 %>
    <em>Baseline tool-call budget per turn (default: 15). Read-heavy analysis and batch requests raise this automatically when needed.</em>
  </p>

  <p>
    <%= label_tag 'settings_max_loop_iterations', 'Max Loop Iterations' %>
    <%= number_field_tag 'settings[max_loop_iterations]', @settings['max_loop_iterations'] || 0, min: 0, max: 150 %>
    <em>Optional hard cap for response/tool loop iterations. Set 0 to auto-calculate from the active tool budget.</em>
  </p>
</div>
