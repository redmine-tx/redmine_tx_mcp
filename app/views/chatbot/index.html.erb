<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'chatbot', plugin: :redmine_tx_mcp %>
  <%= javascript_include_tag 'marked.min', plugin: :redmine_tx_mcp %>
  <%= javascript_include_tag 'purify.min', plugin: :redmine_tx_mcp %>
  <%= javascript_include_tag 'chatbot', plugin: :redmine_tx_mcp %>
<% end %>

<% html_title 'AI Assistant' %>
<h2>AI Assistant</h2>

<div class="chat-layout">
  <div class="box chat-nav-sidebar">
    <div class="chat-nav-panel">
      <%= button_to '새 대화', create_chatbot_conversation_path(@project), method: :post,
                    class: 'btn btn-primary chat-new-conversation-btn',
                    form: { class: 'chat-new-conversation-form' } %>

      <div class="chat-session-section">
        <h3>Recent Sessions</h3>
        <p class="chat-session-help">현재 프로젝트에서 최근에 사용한 대화입니다.</p>
        <ul id="chat-session-list" class="chat-session-list">
          <% if @recent_chat_sessions.any? %>
            <% @recent_chat_sessions.each do |chat_session| %>
              <% touched_at = chat_session.last_message_at || chat_session.updated_at || chat_session.created_at %>
              <% local_touched_at = User.current.convert_time_to_user_timezone(touched_at) %>
              <li class="chat-session-item">
                <a href="<%= project_chatbot_path(@project, conversation: chat_session.session_id) %>"
                   class="chat-session-link<%= ' active' if chat_session.session_id == @chatbot_session_id %>">
                  <span class="chat-session-title"><%= h(chat_session.display_title) %></span>
                  <span class="chat-session-meta">
                    <%= local_touched_at.to_date == User.current.today ? local_touched_at.strftime('%H:%M') : local_touched_at.strftime('%m-%d') %>
                  </span>
                </a>
                <a href="#" class="chat-session-delete icon icon-del"
                   data-session-id="<%= chat_session.session_id %>"
                   onclick="deleteSession('<%= chat_session.session_id %>'); return false;"
                   title="삭제"></a>
              </li>
            <% end %>
          <% else %>
            <li class="chat-session-empty">No recent sessions</li>
          <% end %>
        </ul>
      </div>

      <div class="workspace-panel">
        <h3>Session Files</h3>
        <p class="workspace-help">Uploaded files and generated reports are isolated per user and chatbot session.</p>

        <div class="workspace-block">
          <h4>Uploads</h4>
          <ul id="workspace-uploads" class="workspace-list">
            <% if @workspace_uploads.any? %>
              <% @workspace_uploads.each do |file| %>
                <li>
                  <span class="workspace-name"><%= h(file[:stored_name]) %></span>
                  <span class="workspace-meta"><%= h(file[:size_label]) %></span>
                </li>
              <% end %>
            <% else %>
              <li class="workspace-empty">No uploaded files</li>
            <% end %>
          </ul>
        </div>

        <div class="workspace-block">
          <h4>Reports</h4>
          <ul id="workspace-reports" class="workspace-list">
            <% if @workspace_reports.any? %>
              <% @workspace_reports.each do |file| %>
                <li>
                  <a href="<%= h(file[:download_path]) %>" class="workspace-link"><%= h(file[:stored_name]) %></a>
                  <span class="workspace-meta"><%= h(file[:size_label]) %></span>
                </li>
              <% end %>
            <% else %>
              <li class="workspace-empty">No generated reports</li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="box chat-shell">
    <div id="chat-container" class="chat-container">
      <div class="chat-session-header">
        <h3 id="chat-session-heading"><%= h(@active_chat_session.display_title) %></h3>
      </div>

      <div id="chat-messages" class="chat-messages">
        <% @conversation_history.each do |msg| %>
          <div class="message <%= msg['role'] %>">
            <div class="message-content<%= ' markdown-body' if msg['role'] == 'assistant' %>"
                 <% if msg['role'] == 'assistant' %>data-raw="<%= h(msg['content']) %>"<% end %>>
              <%= simple_format(h(msg['content'])) %>
            </div>
            <div class="message-time">
              <%= begin
                    ts = msg['timestamp'].to_s
                    if ts.match?(/\A\d{1,2}:\d{2}\z/)
                      ts
                    else
                      User.current.convert_time_to_user_timezone(Time.parse(ts)).strftime("%H:%M")
                    end
                  rescue
                    ''
                  end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="chat-input-container">
        <%= form_with url: chat_submit_chatbot_path(@project), local: true,
                     html: { id: 'chat-form', class: 'chat-form', multipart: true } do |form| %>
          <%= hidden_field_tag :conversation, @chatbot_session_id, id: 'chat-conversation-id' %>
          <div class="input-group">
            <%= form.text_area :message, placeholder: "Ask about this project or use the uploaded spreadsheet...",
                              rows: 2, class: 'chat-input', id: 'chat-input' %>
            <%= form.submit "Send", class: 'btn btn-primary chat-send-btn', id: 'send-btn' %>
          </div>

          <div class="chat-file-row">
            <label for="chat-files" class="chat-file-label">Attach spreadsheet</label>
            <%= file_field_tag 'files[]', multiple: true, accept: '.xlsx,.csv,.tsv',
                              class: 'chat-file-input', id: 'chat-files' %>
            <div id="chat-files-help" class="chat-files-help">
              Supports `.xlsx`, `.csv`, `.tsv`. Files are isolated to your current user/session.
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
var activePlanMessageEl = null;

document.addEventListener('DOMContentLoaded', function() {
  renderExistingMarkdown();
  initializeChatbot();
});

function renderMarkdown(text) {
  if (typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined') {
    var raw = marked.parse(text, { breaks: true, gfm: true });
    return DOMPurify.sanitize(raw);
  }
  return escapeHtml(text).replace(/\n/g, '<br>');
}

function renderExistingMarkdown() {
  var els = document.querySelectorAll('.message.assistant .message-content.markdown-body[data-raw]');
  for (var i = 0; i < els.length; i++) {
    var raw = els[i].getAttribute('data-raw');
    if (raw) els[i].innerHTML = renderMarkdown(raw);
  }
}

function initializeChatbot() {
  var form = document.getElementById('chat-form');
  var input = document.getElementById('chat-input');
  var fileInput = document.getElementById('chat-files');
  var fileHelp = document.getElementById('chat-files-help');
  var sendBtn = document.getElementById('send-btn');
  var csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

  input.focus();
  updateSelectedFiles(fileInput, fileHelp);

  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      form.dispatchEvent(new Event('submit'));
    }
  });

  fileInput.addEventListener('change', function() {
    updateSelectedFiles(fileInput, fileHelp);
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    var message = input.value.trim();
    var fileNames = selectedFileNames(fileInput);
    if (!message && !fileNames.length) return;

    var formData = new FormData(form);
    var displayMessage = message || '[파일 업로드]';
    if (fileNames.length) {
      displayMessage += (message ? '\n' : ' ') + '[첨부 파일] ' + fileNames.join(', ');
    }
    addMessage('user', displayMessage);
    activePlanMessageEl = null;

    input.disabled = true;
    fileInput.disabled = true;
    sendBtn.disabled = true;
    sendBtn.textContent = 'Sending...';

    input.value = '';

    sendStreamingRequest(form.action, formData, csrfToken)
      .finally(function() {
        input.disabled = false;
        fileInput.disabled = false;
        sendBtn.disabled = false;
        sendBtn.textContent = 'Send';
        fileInput.value = '';
        updateSelectedFiles(fileInput, fileHelp);
        input.focus();
      });
  });
}

function sendStreamingRequest(url, formData, csrfToken) {
  var statusEl = showStatus('Connecting...');

  return fetch(url, {
    method: 'POST',
    headers: {
      'Accept': 'text/event-stream',
      'X-CSRF-Token': csrfToken
    },
    body: formData
  })
  .then(function(response) {
    var contentType = response.headers.get('Content-Type') || '';

    if (contentType.indexOf('application/json') !== -1) {
      return response.json().then(function(data) {
        removeStatus(statusEl);
        if (data.workspace) updateWorkspacePanels(data.workspace);
        if (data.sessions) updateSessionList(data.sessions);
        if (data.success) {
          addMessage('assistant', data.message);
        } else {
          addMessage('error', data.error || 'An error occurred');
        }
      });
    }

    var reader = response.body.getReader();
    var decoder = new TextDecoder();
    var buffer = '';

    function processStream() {
      return reader.read().then(function(result) {
        if (result.done) {
          removeStatus(statusEl);
          return;
        }

        buffer += decoder.decode(result.value, { stream: true });
        var parts = buffer.split('\n\n');
        buffer = parts.pop();

        for (var i = 0; i < parts.length; i++) {
          var lines = parts[i].split('\n');
          for (var j = 0; j < lines.length; j++) {
            if (lines[j].indexOf('data: ') === 0) {
              try {
                var event = JSON.parse(lines[j].substring(6));
                handleStreamEvent(event, statusEl);
              } catch (e) {}
            }
          }
        }

        return processStream();
      });
    }

    return processStream();
  })
  .catch(function(error) {
    console.error('Stream error:', error);
    removeStatus(statusEl);
    addMessage('error', 'Failed to send message. Please try again.');
  });
}

function handleStreamEvent(event, statusEl) {
  switch (event.type) {
    case 'plan':
      upsertPlanMessage(event);
      updateStatus(statusEl, event.status || 'Working through the plan...');
      break;
    case 'thinking':
      updateStatus(statusEl, event.message);
      break;
    case 'tool_call':
      updateStatus(statusEl, 'Calling ' + formatToolName(event.tool) + '...');
      break;
    case 'tool_result':
      updateStatus(statusEl, formatToolName(event.tool) + ' done');
      break;
    case 'workspace':
      updateWorkspacePanels(event.workspace || {});
      break;
    case 'sessions':
      updateSessionList(event.sessions || {});
      break;
    case 'answer':
      finalizePlanMessage('done');
      removeStatus(statusEl);
      addMessage('assistant', event.message);
      break;
    case 'error':
      finalizePlanMessage('blocked', event.message || 'An error occurred');
      removeStatus(statusEl);
      addMessage('error', event.message || 'An error occurred');
      break;
    case 'done':
      finalizePlanMessage('done');
      removeStatus(statusEl);
      break;
  }
}

function updateWorkspacePanels(workspace) {
  renderWorkspaceList('workspace-uploads', workspace.uploads || [], false);
  renderWorkspaceList('workspace-reports', workspace.reports || [], true);
}

function updateSessionList(payload) {
  payload = payload || {};
  renderSessionList(payload.items || [], payload.active_session_id || '');
}

function renderSessionList(items, activeSessionId) {
  var list = document.getElementById('chat-session-list');
  if (!list) return;

  if (!items.length) {
    list.innerHTML = '<li class="chat-session-empty">No recent sessions</li>';
    return;
  }

  var html = [];
  var activeTitle = '';

  for (var i = 0; i < items.length; i++) {
    var item = items[i] || {};
    var active = item.session_id === activeSessionId || item.active;
    if (active && item.title) activeTitle = item.title;

    var sid = escapeHtml(item.session_id || '');
    html.push(
      '<li class="chat-session-item">' +
        '<a href="' + escapeHtml(item.path || '#') + '" class="chat-session-link' + (active ? ' active' : '') + '">' +
          '<span class="chat-session-title">' + escapeHtml(item.title || '새 대화') + '</span>' +
          '<span class="chat-session-meta">' + escapeHtml(item.updated_label || '') + '</span>' +
        '</a>' +
        '<a href="#" class="chat-session-delete icon icon-del" data-session-id="' + sid + '" onclick="deleteSession(\'' + sid + '\'); return false;" title="삭제"></a>' +
      '</li>'
    );
  }

  list.innerHTML = html.join('');
  updateConversationField(activeSessionId);
  updateSessionHeading(activeTitle || '새 대화');
}

function renderWorkspaceList(elementId, items, linkItems) {
  var list = document.getElementById(elementId);
  if (!list) return;

  if (!items.length) {
    list.innerHTML = '<li class="workspace-empty">' + (linkItems ? 'No generated reports' : 'No uploaded files') + '</li>';
    return;
  }

  var html = [];
  for (var i = 0; i < items.length; i++) {
    var item = items[i];
    var label = escapeHtml(item.stored_name || '');
    var meta = escapeHtml(item.size_label || '');
    if (linkItems && item.download_path) {
      html.push('<li><a class="workspace-link" href="' + escapeHtml(item.download_path) + '">' + label + '</a><span class="workspace-meta">' + meta + '</span></li>');
    } else {
      html.push('<li><span class="workspace-name">' + label + '</span><span class="workspace-meta">' + meta + '</span></li>');
    }
  }

  list.innerHTML = html.join('');
}

function selectedFileNames(fileInput) {
  if (!fileInput || !fileInput.files) return [];
  var names = [];
  for (var i = 0; i < fileInput.files.length; i++) {
    names.push(fileInput.files[i].name);
  }
  return names;
}

function updateSelectedFiles(fileInput, fileHelp) {
  if (!fileHelp) return;
  var names = selectedFileNames(fileInput);
  if (!names.length) {
    fileHelp.textContent = 'Supports .xlsx, .csv, .tsv. Files are isolated to your current user/session.';
    return;
  }
  fileHelp.textContent = 'Selected: ' + names.join(', ');
}

function formatToolName(name) {
  if (!name) return 'tool';
  return name.replace(/_/g, ' ');
}

function createPlanMessage() {
  var container = document.getElementById('chat-messages');
  var messageDiv = document.createElement('div');
  messageDiv.className = 'message assistant plan-message is-pending';
  messageDiv.innerHTML =
    '<div class="message-content plan-card">' +
      '<div class="plan-card-header">' +
        '<span class="plan-icon" aria-hidden="true"></span>' +
        '<div class="plan-card-meta">' +
          '<div class="plan-title"></div>' +
          '<div class="plan-status"></div>' +
        '</div>' +
      '</div>' +
      '<ol class="plan-steps"></ol>' +
    '</div>' +
    '<div class="message-time"></div>';

  container.appendChild(messageDiv);
  container.scrollTop = container.scrollHeight;
  return messageDiv;
}

function upsertPlanMessage(event) {
  if (!activePlanMessageEl || !activePlanMessageEl.parentNode) {
    activePlanMessageEl = createPlanMessage();
  }

  var titleEl = activePlanMessageEl.querySelector('.plan-title');
  var statusEl = activePlanMessageEl.querySelector('.plan-status');
  var stepsEl = activePlanMessageEl.querySelector('.plan-steps');
  var timeEl = activePlanMessageEl.querySelector('.message-time');
  var normalizedSteps = normalizePlanSteps(event.steps);

  titleEl.textContent = event.title || 'Plan';
  statusEl.textContent = event.status || '계획을 진행 중입니다.';
  stepsEl.innerHTML = renderPlanSteps(normalizedSteps);
  setPlanMessageState(activePlanMessageEl, planStateFromSteps(normalizedSteps));
  if (timeEl) timeEl.textContent = currentMessageTime();

  var container = document.getElementById('chat-messages');
  container.scrollTop = container.scrollHeight;
}

function normalizePlanSteps(steps) {
  var normalized = [];
  steps = Array.isArray(steps) ? steps : [];

  for (var i = 0; i < steps.length; i++) {
    var step = String(steps[i] || '');
    var match = step.match(/^(pending|in_progress|completed|skipped):\s*(.+)$/);
    if (match) {
      normalized.push({ state: match[1], text: match[2] });
    } else {
      normalized.push({ state: 'pending', text: step });
    }
  }

  return normalized;
}

function renderPlanSteps(steps) {
  var html = [];

  for (var i = 0; i < steps.length; i++) {
    var step = steps[i] || {};
    var state = step.state || 'pending';
    var label = planStepLabel(state);
    html.push(
      '<li class="plan-step ' + escapeHtml(state) + '">' +
        '<span class="plan-step-badge">' + escapeHtml(label) + '</span>' +
        '<span class="plan-step-text">' + escapeHtml(step.text || '') + '</span>' +
      '</li>'
    );
  }

  return html.join('');
}

function planStepLabel(state) {
  switch (state) {
    case 'completed':
      return 'Done';
    case 'in_progress':
      return 'Doing';
    case 'skipped':
      return 'Skip';
    default:
      return 'Plan';
  }
}

function planStateFromSteps(steps) {
  var hasPending = false;
  var hasProgress = false;
  var hasCompleted = false;

  for (var i = 0; i < steps.length; i++) {
    var state = (steps[i] || {}).state;
    if (state === 'in_progress') hasProgress = true;
    if (state === 'completed' || state === 'skipped') hasCompleted = true;
    if (state === 'pending') hasPending = true;
  }

  if (hasProgress) return 'working';
  if (steps.length && !hasPending) return 'done';
  if (hasCompleted) return 'working';
  return 'pending';
}

function setPlanMessageState(messageEl, state) {
  if (!messageEl) return;
  messageEl.classList.remove('is-pending', 'is-working', 'is-done', 'is-blocked');
  messageEl.classList.add('is-' + state);
}

function finalizePlanMessage(state, statusText) {
  if (!activePlanMessageEl || !activePlanMessageEl.parentNode) return;

  setPlanMessageState(activePlanMessageEl, state || 'done');
  if (statusText) {
    var statusEl = activePlanMessageEl.querySelector('.plan-status');
    if (statusEl) statusEl.textContent = statusText;
  }

  var timeEl = activePlanMessageEl.querySelector('.message-time');
  if (timeEl) timeEl.textContent = currentMessageTime();
}

function currentMessageTime() {
  return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

function showStatus(text) {
  var container = document.getElementById('chat-messages');
  var el = document.createElement('div');
  el.className = 'message assistant status-message';
  el.innerHTML = '<div class="message-content status-indicator">' +
    '<span class="status-spinner"></span>' +
    '<span class="status-text">' + escapeHtml(text) + '</span>' +
    '</div>';
  container.appendChild(el);
  container.scrollTop = container.scrollHeight;
  return el;
}

function updateStatus(el, text) {
  if (!el) return;
  var textEl = el.querySelector('.status-text');
  if (textEl) textEl.textContent = text;
  var container = document.getElementById('chat-messages');
  container.scrollTop = container.scrollHeight;
}

function removeStatus(el) {
  if (el && el.parentNode) el.parentNode.removeChild(el);
}

function addMessage(role, content) {
  var container = document.getElementById('chat-messages');
  var messageDiv = document.createElement('div');
  messageDiv.className = 'message ' + role;

  var contentDiv = document.createElement('div');
  if (role === 'assistant') {
    contentDiv.className = 'message-content markdown-body';
    contentDiv.innerHTML = renderMarkdown(content);
  } else {
    contentDiv.className = 'message-content';
    contentDiv.innerHTML = escapeHtml(content).replace(/\n/g, '<br>');
  }

  var timeDiv = document.createElement('div');
  timeDiv.className = 'message-time';
  timeDiv.textContent = currentMessageTime();

  messageDiv.appendChild(contentDiv);
  messageDiv.appendChild(timeDiv);

  container.appendChild(messageDiv);
  container.scrollTop = container.scrollHeight;
}

function updateSessionHeading(title) {
  var heading = document.getElementById('chat-session-heading');
  if (heading) heading.textContent = title || '새 대화';
}

function updateConversationField(sessionId) {
  var input = document.getElementById('chat-conversation-id');
  if (input && sessionId) input.value = sessionId;
}

function escapeHtml(text) {
  var div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function deleteSession(sessionId) {
  if (!confirm('이 대화를 삭제하시겠습니까?')) return;

  var activeSessionId = (document.getElementById('chat-conversation-id') || {}).value || '';
  var isActive = sessionId === activeSessionId;

  fetch('<%= reset_chatbot_path(@project) %>', {
    method: 'POST',
    headers: {
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
      'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
    },
    body: 'conversation=' + encodeURIComponent(sessionId)
  })
  .then(function(response) {
    return response.json().then(function(data) {
      return { ok: response.ok, data: data };
    });
  })
  .then(function(result) {
    if (result.ok) {
      if (isActive) {
        location.href = result.data.redirect_url || '<%= project_chatbot_path(@project) %>';
      } else {
        removeSessionItem(sessionId);
      }
      return;
    }
    throw new Error((result.data && result.data.error) || '대화를 삭제하지 못했습니다.');
  })
  .catch(function(error) {
    alert(error.message || '대화를 삭제하지 못했습니다.');
  });
}

function removeSessionItem(sessionId) {
  var list = document.getElementById('chat-session-list');
  if (!list) return;

  var items = list.querySelectorAll('.chat-session-item');
  for (var i = 0; i < items.length; i++) {
    var deleteBtn = items[i].querySelector('.chat-session-delete');
    if (deleteBtn && deleteBtn.getAttribute('data-session-id') === sessionId) {
      items[i].remove();
      break;
    }
  }

  if (!list.querySelector('.chat-session-item')) {
    list.innerHTML = '<li class="chat-session-empty">No recent sessions</li>';
  }
}

</script>
