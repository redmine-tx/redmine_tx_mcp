<div class="contextual">
  <%= link_to "Back to MCP Status", mcp_admin_index_path, class: "icon icon-back" %>
</div>

<h2>MCP Settings</h2>

<%= form_tag mcp_admin_update_settings_path do %>
  <div class="box tabular">
    <p>
      <%= check_box_tag 'settings[enabled]', '1', @settings['enabled'] == '1', id: 'settings_enabled' %>
      <%= label_tag 'settings_enabled', 'Enable MCP Server' %>
    </p>

    <p>
      <%= label_tag 'settings_api_key', 'API Key' %>
      <%= text_field_tag 'settings[api_key]', @settings['api_key'], placeholder: 'Enter API key for authentication' %>
      <em>Used to authenticate MCP client connections</em>
    </p>

    <p>
      <%= label_tag 'settings_allowed_origins', 'Allowed Origins' %>
      <%= text_area_tag 'settings[allowed_origins]', @settings['allowed_origins'], rows: 3, placeholder: 'localhost:3000\nexample.com' %>
      <em>One origin per line. Leave blank to allow all origins.</em>
    </p>

    <p>
      <%= label_tag 'settings_log_level', 'Log Level' %>
      <%= select_tag 'settings[log_level]',
            options_for_select([
              ['Debug', 'debug'],
              ['Info', 'info'],
              ['Warn', 'warn'],
              ['Error', 'error']
            ], @settings['log_level'] || 'info') %>
    </p>

    <p>
      <%= label_tag 'settings_max_request_size', 'Max Request Size (KB)' %>
      <%= number_field_tag 'settings[max_request_size]', @settings['max_request_size'] || 1024, min: 1 %>
      <em>Maximum size for MCP requests in KB</em>
    </p>

    <p>
      <%= check_box_tag 'settings[enable_caching]', '1', @settings['enable_caching'] == '1', id: 'settings_enable_caching' %>
      <%= label_tag 'settings_enable_caching', 'Enable Response Caching' %>
      <em>Cache frequently requested data to improve performance</em>
    </p>

    <p>
      <%= label_tag 'settings_cache_ttl', 'Cache TTL (seconds)' %>
      <%= number_field_tag 'settings[cache_ttl]', @settings['cache_ttl'] || 300, min: 1 %>
      <em>Time-to-live for cached responses</em>
    </p>
  </div>

  <%= submit_tag 'Save Settings', class: 'button button-positive' %>
<% end %>

<div class="box">
  <h3>Security Notes</h3>
  <ul>
    <li>The API key should be a strong, randomly generated string</li>
    <li>Restrict allowed origins in production environments</li>
    <li>Monitor log files for suspicious activity</li>
    <li>Regularly rotate API keys</li>
  </ul>
</div>